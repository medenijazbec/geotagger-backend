# ─── DATABASE ───────────────────────────────────────────
DB_CONN_STR=Server=db;Port=3306;Database=geotagger;User=geotagger_user;Password=${DB_PASSWORD}

# ─── JWT ────────────────────────────────────────────────
JWT__KEY=MOUJ_SUPER_SECRET_KEY_1234567890123456
JWT__ISSUER=GeotaggerIssuer
JWT__AUDIENCE=GeotaggerAudience
JWT__EXPIRESINMINUTES=60

# ─── OAUTH ──────────────────────────────────────────────
AUTH__GOOGLE__CLIENTID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
AUTH__GOOGLE__CLIENTSECRET=xxxxxxxxxxxxxxxxxxxxxxxx
AUTH__FACEBOOK__APPID=123456789012345
AUTH__FACEBOOK__APPSECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MISC ───────────────────────────────────────────────
STATICBASEURL=https://cdn.myapp.com          # the value your LocationService needs
